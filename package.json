      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.79",
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.191",
    "browser-image-compression": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "qrcode-generator": "^1.5.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.3"
