  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.9.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
