# Vercel Postgres (auto-populated when you add Vercel Postgres integration)
POSTGRES_URL=

# Cron job secret (set in Vercel dashboard, auto-sent by Vercel crons)
CRON_SECRET=

# AI Provider: "gemini" (default) or "groq"
AI_PROVIDER=gemini

# Google AI (Gemini) - get free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq (alternative) - get free key at https://console.groq.com/keys
GROQ_API_KEY=
